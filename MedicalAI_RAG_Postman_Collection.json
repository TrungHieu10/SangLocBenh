            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"MATCH (d:Disease) RETURN d.name, d.id\"\n}"
            },
            "url": {
              "raw": "http://localhost:7687",
              "protocol": "http",
              "host": ["localhost"],
              "port": "7687"
            },
            "description": "Neo4j Browser Query (run in Browser)"
          },
          "response": []
        }
      ]
