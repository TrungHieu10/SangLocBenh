        {
          "name": "1. Get Advice - Đái Tháo Đường",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/clinical-rag/advice?disease=Đái tháo đường Type 2&riskScore=0.75",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "clinical-rag", "advice"],
              "query": [
                {
                  "key": "disease",
                  "value": "Đái tháo đường Type 2"
                },
                {
                  "key": "riskScore",
                  "value": "0.75"
                }
              ]
            },
            "description": "Lấy advice cho bệnh Đái tháo đường Type 2 với risk score 75%"
          },
          "response": []
