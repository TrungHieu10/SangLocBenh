            "body": {
              "mode": "raw",
              "raw": "{\n  \"age\": 45,\n  \"systolicBP\": 150,\n  \"diastolicBP\": 90,\n  \"heartRate\": 85,\n  \"temperature\": 36.5,\n  \"weight\": 85,\n  \"height\": 170,\n  \"bloodGlucose\": 180,\n  \"totalCholesterol\": 220,\n  \"ldl\": 140,\n  \"hdl\": 35,\n  \"triglycerides\": 200\n}"
