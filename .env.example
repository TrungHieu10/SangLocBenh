# ==========================================
# MEDICAL AI SYSTEM - ENVIRONMENT VARIABLES
# ==========================================
# Hướng dẫn: 
# 1. Copy file này thành .env (cp .env.example .env)
# 2. Điền các giá trị bảo mật vào file .env
# 3. File .env đã được cấu hình ẩn khỏi Git để bảo mật

# 1. Backend Secrets (Bắt buộc)
# Mật khẩu database SQL Server (Tối thiểu 8 ký tự, chữ hoa, số, ký tự đặc biệt)
DB_PASSWORD=Strong_Password123!

# Chuỗi bí mật để ký JWT Token (Cần một chuỗi dài và phức tạp)
JWT_SECRET_KEY=Day_La_Mot_Chuoi_Bi_Mat_Y_Te_Rat_Dai_Va_Kho_Doan_123456

# Mật khẩu App Email (Dùng để gửi mail quên mật khẩu)
EMAIL_PASSWORD=qkdi_firp_jkhm_wyoj

# Mật khẩu Neo4j (Đồ thị tri thức y khoa)
NEO4J_PASSWORD=MatKhauNeo4j123

# API Key của OpenRouter (Để gọi LLM RAG)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxx

# 2. Frontend Secrets
# Google OAuth Client ID (Dành cho đăng nhập bằng Google)
